<PluginUserControl x:Class="UniPlaySong.Controls.MediaControllerOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniPlaySong.Controls"
    HorizontalAlignment="Left" VerticalAlignment="Top"
    mc:Ignorable="d">
    <PluginUserControl.Resources>
        <BooleanToVisibilityConverter x:Key="UpsBoolToVis"/>
        <!-- Circular icon transport button: borderless, transparent, hover/press ring, dims when disabled. -->
        <Style x:Key="UpsIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F2FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="ring" Fill="Transparent" Stroke="Transparent" StrokeThickness="2"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ring" Property="Fill" Value="#22FFFFFF"/></Trigger>
                            <!-- Controller/keyboard focus highlight (no mouse pointer in Fullscreen) -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ring" Property="Fill" Value="#33FFFFFF"/>
                                <Setter TargetName="ring" Property="Stroke" Value="#FFFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ring" Property="Fill" Value="#3AFFFFFF"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.28"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Primary play/pause: filled white circle, dark glyph. -->
        <Style x:Key="UpsPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#101418"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Focus halo (behind the white disc), shown only on keyboard/controller focus -->
                            <Ellipse x:Name="halo" Fill="Transparent" Margin="-4"/>
                            <Ellipse x:Name="ring" Fill="#FFFFFF" Stroke="Transparent" StrokeThickness="2"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ring" Property="Fill" Value="#E6FFFFFF"/></Trigger>
                            <!-- Controller/keyboard focus highlight -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="halo" Property="Fill" Value="#59FFFFFF"/>
                                <Setter TargetName="ring" Property="Stroke" Value="#FF3DA5FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ring" Property="Fill" Value="#CCFFFFFF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </PluginUserControl.Resources>

    <PluginUserControl.Style>
        <Style TargetType="PluginUserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveMedia}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </PluginUserControl.Style>

    <Border Background="#E60E1116" CornerRadius="16" Padding="22" MinWidth="360" MaxWidth="420">
        <StackPanel>
            <!-- Album art -->
            <Border CornerRadius="10" ClipToBounds="True" Margin="0,0,0,16" HorizontalAlignment="Center"
                    Visibility="{Binding HasArt, Converter={StaticResource UpsBoolToVis}}">
                <Image Source="{Binding AlbumArtPath}" Height="240" Stretch="Uniform"/>
            </Border>

            <!-- Source label + title + artist -->
            <TextBlock Text="{Binding SourceName}" FontSize="11" Opacity="0.5" Margin="2,0,0,2" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding Title}" FontSize="22" FontWeight="SemiBold" Foreground="#FFFFFF"
                       TextTrimming="CharacterEllipsis" Margin="2,0,0,1"/>
            <TextBlock Text="{Binding Artist}" FontSize="14" Opacity="0.72" Foreground="#FFFFFF"
                       TextTrimming="CharacterEllipsis" Margin="2,0,0,14"/>

            <!-- Timeline -->
            <Grid Visibility="{Binding HasTimeline, Converter={StaticResource UpsBoolToVis}}" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding PositionText}" FontSize="11" Opacity="0.6"
                           Foreground="#FFFFFF" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding Progress, Mode=OneWay}"
                             Height="4" VerticalAlignment="Center" Foreground="#FFFFFF" Background="#26FFFFFF"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="2" Text="{Binding DurationText}" FontSize="11" Opacity="0.6"
                           Foreground="#FFFFFF" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>

            <!-- Transport row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,4">
                <Button Style="{StaticResource UpsIconButton}" Command="{Binding PreviousCommand}"
                        IsEnabled="{Binding CanPrevious}" Content="&#xEC78;" FontFamily="{DynamicResource FontIcoFont}"
                        FontSize="20" Width="46" Height="46" Margin="6,0"
                        Focusable="True" local:GamepadConfirm.IsTarget="True"/>
                <Button Command="{Binding PlayPauseCommand}" FontFamily="{DynamicResource FontIcoFont}"
                        FontSize="26" Width="64" Height="64" Margin="8,0"
                        Focusable="True" local:GamepadConfirm.IsTarget="True">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource UpsPrimaryButton}">
                            <Setter Property="Content" Value="&#xECA5;"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                    <Setter Property="Content" Value="&#xECA6;"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Style="{StaticResource UpsIconButton}" Command="{Binding NextCommand}"
                        IsEnabled="{Binding CanNext}" Content="&#xEC6E;" FontFamily="{DynamicResource FontIcoFont}"
                        FontSize="20" Width="46" Height="46" Margin="6,0"
                        Focusable="True" local:GamepadConfirm.IsTarget="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</PluginUserControl>
