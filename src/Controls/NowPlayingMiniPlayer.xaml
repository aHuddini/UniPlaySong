<PluginUserControl x:Class="UniPlaySong.Controls.NowPlayingMiniPlayer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniPlaySong.Controls"
    HorizontalAlignment="Left" VerticalAlignment="Top"
    mc:Ignorable="d">
    <PluginUserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </PluginUserControl.Resources>
    <!-- Whole control collapses when nothing is playing. Glass-pill default look. -->
    <Border Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}"
            Background="#9E0F0F14" CornerRadius="8" Padding="10,8"
            BorderBrush="#1AFFFFFF" BorderThickness="1" HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal">
            <Grid Width="46" Height="46" Margin="0,0,12,0">
                <Border Background="#33000000" CornerRadius="5"/>
                <TextBlock Text="&#x266A;" FontSize="22" Foreground="White" Opacity="0.55"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasNoArt, Converter={StaticResource BoolToVis}}"/>
                <Image Source="{Binding AlbumArtPath}" Stretch="UniformToFill"
                       Visibility="{Binding HasArt, Converter={StaticResource BoolToVis}}"/>
            </Grid>
            <StackPanel VerticalAlignment="Center" MaxWidth="260">
                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold"
                           FontSize="14" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Artist}" Foreground="White" Opacity="0.78"
                           FontSize="12" TextTrimming="CharacterEllipsis"/>
                <!-- Spotify-only sub-line; each piece hides when empty (all empty for game music). -->
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Text="{Binding Album}" Foreground="White" Opacity="0.52" FontSize="11"
                               TextTrimming="CharacterEllipsis" MaxWidth="150"
                               Visibility="{Binding HasAlbum, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding Genre}" Foreground="White" Opacity="0.52" FontSize="11"
                               Margin="6,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="120"
                               Visibility="{Binding HasGenre, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding Duration}" Foreground="White" Opacity="0.52" FontSize="11"
                               Margin="6,0,0,0"
                               Visibility="{Binding HasDuration, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</PluginUserControl>
