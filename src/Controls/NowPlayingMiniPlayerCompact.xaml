<PluginUserControl x:Class="UniPlaySong.Controls.NowPlayingMiniPlayerCompact"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniPlaySong.Controls"
    HorizontalAlignment="Left" VerticalAlignment="Top"
    mc:Ignorable="d">
    <PluginUserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </PluginUserControl.Resources>
    <!-- One-liner: "♪ Title · Artist · Duration". Collapses when nothing is playing. -->
    <Border Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}"
            Background="#9E0F0F14" CornerRadius="8" Padding="13,7"
            BorderBrush="#1AFFFFFF" BorderThickness="1" HorizontalAlignment="Left">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#x266A;" Foreground="#E0556A" FontSize="14" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13" Margin="8,0,0,0"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
            <TextBlock Text="{Binding Artist}" Foreground="White" Opacity="0.78" FontSize="13"
                       Margin="6,0,0,0" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" MaxWidth="180"/>
            <TextBlock Foreground="White" Opacity="0.52" FontSize="11" Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       Visibility="{Binding HasDuration, Converter={StaticResource BoolToVis}}">
                <Run Text="&#183; "/><Run Text="{Binding Duration, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>
    </Border>
</PluginUserControl>
