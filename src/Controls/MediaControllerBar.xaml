<PluginUserControl x:Class="UniPlaySong.Controls.MediaControllerBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniPlaySong.Controls"
    mc:Ignorable="d">
    <PluginUserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </PluginUserControl.Resources>
    <PluginUserControl.Style>
        <Style TargetType="PluginUserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveMedia}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </PluginUserControl.Style>
    <Border Background="#25000000" CornerRadius="10" Padding="8,5">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image Source="{Binding AlbumArtPath}" Width="34" Height="34" Margin="0,0,8,0"
                   Stretch="UniformToFill" Visibility="{Binding HasArt, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <StackPanel VerticalAlignment="Center" Margin="0,0,10,0" MaxWidth="220">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding Artist}" FontSize="11" Opacity="0.75" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Button Command="{Binding PreviousCommand}" IsEnabled="{Binding CanPrevious}" Content="&#xEC78;" FontFamily="{DynamicResource FontIcoFont}" Margin="2,0" Width="28" Height="28"/>
            <Button Command="{Binding PlayPauseCommand}" FontFamily="{DynamicResource FontIcoFont}" Margin="2,0" Width="32" Height="32">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="&#xECA5;"/> <!-- pause glyph -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                <Setter Property="Content" Value="&#xECA6;"/> <!-- play glyph -->
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Command="{Binding NextCommand}" IsEnabled="{Binding CanNext}" Content="&#xEC6E;" FontFamily="{DynamicResource FontIcoFont}" Margin="2,0" Width="28" Height="28"/>
        </StackPanel>
    </Border>
</PluginUserControl>
