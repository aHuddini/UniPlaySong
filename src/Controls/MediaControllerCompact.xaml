<PluginUserControl x:Class="UniPlaySong.Controls.MediaControllerCompact"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniPlaySong.Controls"
    HorizontalAlignment="Left" VerticalAlignment="Top"
    mc:Ignorable="d">
    <PluginUserControl.Resources>
        <Style x:Key="UpsIconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#F2FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="ring" Fill="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ring" Property="Fill" Value="#22FFFFFF"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ring" Property="Fill" Value="#3AFFFFFF"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.28"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UpsPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#101418"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="ring" Fill="#FFFFFF"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ring" Property="Fill" Value="#E6FFFFFF"/></Trigger>
                            <Trigger Property="IsPressed" Value="True"><Setter TargetName="ring" Property="Fill" Value="#CCFFFFFF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </PluginUserControl.Resources>

    <PluginUserControl.Style>
        <Style TargetType="PluginUserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveMedia}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </PluginUserControl.Style>

    <Border Background="#E60E1116" CornerRadius="10" Padding="8,4">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding Title}" Foreground="#FFFFFF" FontSize="12" Opacity="0.85"
                       VerticalAlignment="Center" MaxWidth="140" TextTrimming="CharacterEllipsis" Margin="2,0,8,0"/>
            <Button Command="{Binding PlayPauseCommand}" FontFamily="{DynamicResource FontIcoFont}"
                    FontSize="14" Width="32" Height="32" Margin="1,0"
                    Focusable="True" local:GamepadConfirm.IsTarget="True">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource UpsPrimaryButton}">
                        <Setter Property="Content" Value="&#xECA5;"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                                <Setter Property="Content" Value="&#xECA6;"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Style="{StaticResource UpsIconButton}" Command="{Binding NextCommand}"
                    IsEnabled="{Binding CanNext}" Content="&#xEC6E;" FontFamily="{DynamicResource FontIcoFont}"
                    FontSize="13" Width="28" Height="28" Margin="1,0"
                    Focusable="True" local:GamepadConfirm.IsTarget="True"/>
        </StackPanel>
    </Border>
</PluginUserControl>
