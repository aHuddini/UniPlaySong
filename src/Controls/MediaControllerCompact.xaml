<PluginUserControl x:Class="UniPlaySong.Controls.MediaControllerCompact"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:UniPlaySong.Controls"
    mc:Ignorable="d">
    <PluginUserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </PluginUserControl.Resources>
    <PluginUserControl.Style>
        <Style TargetType="PluginUserControl">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasActiveMedia}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </PluginUserControl.Style>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="{Binding Title}" FontSize="11" Opacity="0.85" VerticalAlignment="Center"
                   MaxWidth="120" TextTrimming="CharacterEllipsis" Margin="0,0,6,0"/>
        <Button Command="{Binding PlayPauseCommand}" FontFamily="{DynamicResource FontIcoFont}" Margin="2,0" Width="26" Height="26">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Content" Value="&#xECA5;"/> <!-- pause glyph -->
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPlaying}" Value="False">
                            <Setter Property="Content" Value="&#xECA6;"/> <!-- play glyph -->
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>
        <Button Command="{Binding NextCommand}" IsEnabled="{Binding CanNext}" Content="&#xEC6E;" FontFamily="{DynamicResource FontIcoFont}" Margin="2,0" Width="26" Height="26"/>
    </StackPanel>
</PluginUserControl>
