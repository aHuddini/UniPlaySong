<UserControl x:Class="UniPlaySong.DeskMediaControl.MusicLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UniPlaySong.DeskMediaControl"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Tab button style (radio button styled as text tab) -->
        <Style x:Key="TabButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#66FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <StackPanel>
                                <ContentPresenter HorizontalAlignment="Center"/>
                                <Border x:Name="Indicator" Height="2" Background="Transparent"
                                        Margin="0,4,0,0" CornerRadius="1"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource GlyphBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#08FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transport button -->
        <Style x:Key="TransportButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="18" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Play/pause primary button (now-playing bar) -->
        <Style x:Key="PlayPauseButton" TargetType="Button">
            <Setter Property="Background" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="16" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#35FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Game card button -->
        <Style x:Key="GameCardButton" TargetType="Button">
            <Setter Property="Background" Value="#12FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" ClipToBounds="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat card -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#12FFFFFF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <!-- Track row item for Tracks tab -->
        <Style x:Key="AllTrackRowItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBd" Background="Transparent" Padding="0,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
    <DockPanel>
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- NOW PLAYING BAR (persistent top)                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#0e0e20" Padding="16,8"
                BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Cover art -->
                    <ColumnDefinition Width="180"/>    <!-- Song info -->
                    <ColumnDefinition Width="Auto"/>  <!-- Transport -->
                    <ColumnDefinition Width="Auto"/>  <!-- Elapsed -->
                    <ColumnDefinition Width="*"/>     <!-- Progress bar -->
                    <ColumnDefinition Width="Auto"/>  <!-- Remaining -->
                    <ColumnDefinition Width="Auto"/>  <!-- Visualizer -->
                </Grid.ColumnDefinitions>

                <!-- Cover art thumbnail (clickable → expands now playing view) -->
                <Button Grid.Column="0" Command="{Binding ToggleNowPlayingCommand}"
                        Cursor="Hand" ToolTip="Expand Now Playing">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ArtBd" Width="42" Height="42" CornerRadius="6"
                                    Background="#1a1a2e" ClipToBounds="True" Margin="0,0,12,0"
                                    Opacity="1.0">
                                <Image Source="{Binding CoverArt}" Stretch="UniformToFill"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ArtBd" Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Song info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="{Binding SongTitle}" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource TextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock FontSize="10" Foreground="#88FFFFFF" TextTrimming="CharacterEllipsis">
                        <Run Text="{Binding SongArtist, Mode=OneWay}"/>
                        <Run Text=" — " Foreground="#44FFFFFF"/>
                        <Run Text="{Binding NowPlayingGameName, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Transport controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <!-- Previous -->
                    <Button Width="32" Height="32" Command="{Binding PreviousCommand}"
                            Style="{StaticResource TransportButton}" ToolTip="Previous">
                        <TextBlock Text="&#xEC78;" FontFamily="{DynamicResource FontIcoFont}"
                                   FontSize="14" Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Play/Pause -->
                    <Button Command="{Binding PlayPauseCommand}" Margin="4,0"
                            Style="{StaticResource PlayPauseButton}" ToolTip="Play / Pause">
                        <TextBlock Text="{Binding PlayPauseIcon}"
                                   FontFamily="{DynamicResource FontIcoFont}"
                                   FontSize="15" Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Skip -->
                    <Button Command="{Binding SkipCommand}" Width="32" Height="32"
                            IsEnabled="{Binding CanSkip}"
                            Style="{StaticResource TransportButton}" ToolTip="Skip to next song">
                        <TextBlock Text="&#xEC6E;" FontFamily="{DynamicResource FontIcoFont}"
                                   FontSize="14" Foreground="{DynamicResource TextBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Elapsed time -->
                <TextBlock Grid.Column="3" Text="{Binding ElapsedTime}" FontSize="10"
                           Foreground="#55FFFFFF" VerticalAlignment="Center" Margin="0,0,6,0"/>

                <!-- Progress bar -->
                <Grid Grid.Column="4" Height="4" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Border Background="#20FFFFFF" CornerRadius="2"/>
                    <Border Background="{DynamicResource GlyphBrush}" CornerRadius="2"
                            HorizontalAlignment="Left">
                        <Border.Width>
                            <MultiBinding Converter="{x:Static local:ProgressWidthConverter.Instance}">
                                <Binding Path="ProgressPercent"/>
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Grid>

                <!-- Remaining time -->
                <TextBlock Grid.Column="5" Text="{Binding RemainingTime}" FontSize="10"
                           Foreground="#55FFFFFF" VerticalAlignment="Center" Margin="0,0,12,0"/>

                <!-- Mini visualizer -->
                <Border x:Name="VisualizerContainer" Grid.Column="6" Width="80" Height="32"
                        Background="#08FFFFFF" CornerRadius="4" ClipToBounds="True"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- TAB BAR                                                        -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Background="#12122a" BorderBrush="#20FFFFFF"
                BorderThickness="0,0,0,1" Padding="12,0">
            <DockPanel>
                <!-- Radio mode button (dock right BEFORE tabs so DockPanel allocates space) -->
                <Button DockPanel.Dock="Right" Command="{Binding RadioModeCommand}"
                        Margin="8,4" ToolTip="Radio mode — shuffle all library music"
                        Style="{StaticResource TransportButton}" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xECB0;" FontFamily="{DynamicResource FontIcoFont}"
                                   FontSize="13" Foreground="{DynamicResource GlyphBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Radio" FontSize="11" Foreground="{DynamicResource TextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Search box -->
                <Border DockPanel.Dock="Right"
                        Background="#15FFFFFF" CornerRadius="6" Padding="8,5" Width="200"
                        Margin="8,4" VerticalAlignment="Center">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="&#xED11;"
                                   FontFamily="{DynamicResource FontIcoFont}"
                                   FontSize="12" Foreground="#55FFFFFF" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource TextBrush}" FontSize="12"
                                 VerticalAlignment="Center" TextChanged="OnSearchTextChanged"
                                 CaretBrush="{DynamicResource TextBrush}"/>
                    </DockPanel>
                </Border>

                <!-- Tabs (fill remaining space) -->
                <StackPanel Orientation="Horizontal">
                    <RadioButton Content="Games" IsChecked="True" GroupName="LibTabs"
                                 Style="{StaticResource TabButton}" Click="OnTabClick" Tag="0"/>
                    <RadioButton Content="Tracks" GroupName="LibTabs"
                                 Style="{StaticResource TabButton}" Click="OnTabClick" Tag="1"/>
                    <RadioButton Content="Artists" GroupName="LibTabs"
                                 Style="{StaticResource TabButton}" Click="OnTabClick" Tag="2"/>
                    <RadioButton Content="Genres" GroupName="LibTabs"
                                 Style="{StaticResource TabButton}" Click="OnTabClick" Tag="3"/>
                    <RadioButton Content="Stats" GroupName="LibTabs"
                                 Style="{StaticResource TabButton}" Click="OnTabClick" Tag="4"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- CONTENT AREA (tab panels stacked, visibility toggled)          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid>
            <!-- Panel 0: Games Tab -->
            <Grid x:Name="GamesPanel">
                <!-- Games grid (shown when no game selected) -->
                <!-- Search results list (shown when search is active) -->
                <ScrollViewer x:Name="SearchResultsScroller" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Visibility="{Binding HasSearchText, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                    <StackPanel Margin="20,12">
                        <TextBlock FontSize="13" Foreground="#88FFFFFF" Margin="0,0,0,10">
                            <Run Text="Search results for &#x22;"/>
                            <Run Text="{Binding SearchText, Mode=OneWay}"/>
                            <Run Text="&#x22;"/>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding FilteredGames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource GameCardButton}"
                                            Margin="0,3" Click="OnGameCardClick" Tag="{Binding}">
                                        <Grid Margin="12,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Cover art (larger for search results) -->
                                            <Border Grid.Column="0" Width="64" Height="64" CornerRadius="6"
                                                    Background="#1a1a2e" ClipToBounds="True" Margin="0,0,14,0">
                                                <Image Source="{Binding CoverArt}" Stretch="UniformToFill"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>

                                            <!-- Game info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="15"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                           Foreground="#9B8EC4" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <!-- Playing indicator -->
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                                       Margin="8,0" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrentlyPlaying}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Text" Value="&#xECBA;"/>
                                                                <Setter Property="FontFamily" Value="{DynamicResource FontIcoFont}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Play button -->
                                            <Button Grid.Column="3" Width="36" Height="36"
                                                    VerticalAlignment="Center" Cursor="Hand"
                                                    Click="OnGamePlayClick" Tag="{Binding}"
                                                    Style="{StaticResource TransportButton}">
                                                <TextBlock Text="&#xECA6;"
                                                           FontFamily="{DynamicResource FontIcoFont}"
                                                           FontSize="16" Foreground="#55FFFFFF"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Button>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Games grid (shown when no search and no game selected) -->
                <ScrollViewer x:Name="GamesGridScroller" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              SizeChanged="OnGamesGridSizeChanged">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSearchText}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsGameDetailVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl x:Name="GamesGrid" ItemsSource="{Binding FilteredGames}"
                                  Margin="12,12,12,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid x:Name="GamesUniformGrid" Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource GameCardButton}"
                                        Margin="4" Click="OnGameCardClick" Tag="{Binding}">
                                    <Grid Margin="10,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Game icon (square) -->
                                        <Border Grid.Column="0" Width="48" Height="48" CornerRadius="6"
                                                Background="#1a1a2e" ClipToBounds="True" Margin="0,0,12,0">
                                            <Image Source="{Binding CoverArt}" Stretch="UniformToFill"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Game info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                                       Foreground="#9B8EC4" Margin="0,3,0,0"/>
                                        </StackPanel>

                                        <!-- Play button / playing indicator -->
                                        <Button Grid.Column="2" Width="32" Height="32"
                                                VerticalAlignment="Center" Cursor="Hand"
                                                Click="OnGamePlayClick" Tag="{Binding}"
                                                Style="{StaticResource TransportButton}">
                                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xECA6;"/>
                                                        <Setter Property="FontFamily" Value="{DynamicResource FontIcoFont}"/>
                                                        <Setter Property="FontSize" Value="16"/>
                                                        <Setter Property="Foreground" Value="#55FFFFFF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCurrentlyPlaying}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Game detail (shown when a game is selected) -->
                <Grid x:Name="DetailPanel"
                      Visibility="{Binding IsGameDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                    <DockPanel>
                        <!-- Back button -->
                        <Button DockPanel.Dock="Top" Command="{Binding BackToGamesCommand}"
                                HorizontalAlignment="Left" Margin="20,12,0,0"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                Foreground="#88FFFFFF" FontSize="12">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock x:Name="Tb" Text="&#x2190; Back to Games"
                                               Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"/>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Tb" Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Hero header -->
                        <Border DockPanel.Dock="Top" Padding="24,16,24,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#442d1b69" Offset="0"/>
                                    <GradientStop Color="#1112122a" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="140" Height="140" CornerRadius="8"
                                        Background="#1a1a2e" ClipToBounds="True" Margin="0,0,20,0">
                                    <Image Source="{Binding SelectedGame.CoverArt}" Stretch="UniformToFill"
                                           VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                                    <TextBlock Text="GAME SOUNDTRACK" FontSize="10" Foreground="#88FFFFFF"
                                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding SelectedGame.Name}" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding SelectedGame.Subtitle}" FontSize="12"
                                               Foreground="#AAFFFFFF" Margin="0,6,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <Button Command="{Binding PlayAllCommand}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="{DynamicResource GlyphBrush}"
                                                            CornerRadius="20" Padding="16,8">
                                                        <TextBlock Text="&#x25B6;  Play All" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="White"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Border Background="#30FFFFFF" CornerRadius="20" Padding="16,8"
                                                Margin="10,0,0,0" Opacity="0.5" ToolTip="Shuffle coming soon">
                                            <TextBlock Text="Shuffle" FontSize="12" Foreground="#CCFFFFFF"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Track list column headers -->
                        <Grid DockPanel.Dock="Top" Margin="28,10,28,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#" FontSize="10" Foreground="#55FFFFFF"/>
                            <TextBlock Grid.Column="1" Text="TITLE" FontSize="10" Foreground="#55FFFFFF"/>
                            <TextBlock Grid.Column="2" Text="ARTIST" FontSize="10" Foreground="#55FFFFFF"/>
                            <TextBlock Grid.Column="3" Text="DURATION" FontSize="10" Foreground="#55FFFFFF"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                        <Border DockPanel.Dock="Top" Height="1" Background="#15FFFFFF" Margin="28,0"/>

                        <!-- Track list -->
                        <ListBox x:Name="DetailTrackListBox" ItemsSource="{Binding GameDetailSongs}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 MouseDoubleClick="OnDetailTrackDoubleClick"
                                 ItemContainerStyle="{StaticResource AllTrackRowItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="28,6,28,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#55FFFFFF"/>
                                                    <Setter Property="Text" Value="{Binding TrackNumber}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentlyPlaying}" Value="True">
                                                            <Setter Property="Text" Value="&#xECA6;"/>
                                                            <Setter Property="FontFamily" Value="{DynamicResource FontIcoFont}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
                                                            <Setter Property="FontSize" Value="12"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                   Margin="0,0,8,0" FontSize="13">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCurrentlyPlaying}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Text="{Binding Artist}" FontSize="11"
                                                   Foreground="#66FFFFFF" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{Binding DurationText}" FontSize="11"
                                                   Foreground="#55FFFFFF" VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Grid>
            </Grid>

            <!-- Panel 1: Tracks Tab -->
            <Grid x:Name="TracksPanel" Visibility="Collapsed">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="28,12,28,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*" MaxWidth="300"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="10" Foreground="#55FFFFFF"/>
                        <TextBlock Grid.Column="1" Text="TITLE" FontSize="10" Foreground="#55FFFFFF"/>
                        <TextBlock Grid.Column="2" Text="ARTIST" FontSize="10" Foreground="#55FFFFFF"/>
                        <TextBlock Grid.Column="3" Text="GAME" FontSize="10" Foreground="#55FFFFFF"/>
                        <TextBlock Grid.Column="4" Text="DURATION" FontSize="10"
                                   Foreground="#55FFFFFF" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border DockPanel.Dock="Top" Height="1" Background="#15FFFFFF" Margin="28,0"/>

                    <ListBox x:Name="AllTracksListBox" ItemsSource="{Binding AllTracks}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             MouseDoubleClick="OnAllTrackDoubleClick"
                             ItemContainerStyle="{StaticResource AllTrackRowItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="28,6,28,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*" MaxWidth="300"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#55FFFFFF"/>
                                                <Setter Property="Text" Value="{Binding TrackNumber}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentlyPlaying}" Value="True">
                                                        <Setter Property="Text" Value="&#xECA6;"/>
                                                        <Setter Property="FontFamily" Value="{DynamicResource FontIcoFont}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               Margin="0,0,8,0" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCurrentlyPlaying}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="2" Text="{Binding Artist}" FontSize="11"
                                               Foreground="#66FFFFFF" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding GameName}" FontSize="11"
                                               Foreground="#55FFFFFF" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="4" Text="{Binding DurationText}" FontSize="11"
                                               Foreground="#55FFFFFF" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Grid>

            <!-- Panel 2: Artists Tab (placeholder) -->
            <Grid x:Name="ArtistsPanel" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xECA1;" FontFamily="{DynamicResource FontIcoFont}"
                               FontSize="48" Foreground="#33FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Artist browsing coming soon" FontSize="16"
                               Foreground="#66FFFFFF" Margin="0,12,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="Metadata support is planned for a future update."
                               FontSize="12" Foreground="#44FFFFFF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Panel 3: Genres Tab (placeholder) -->
            <Grid x:Name="GenresPanel" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="&#xECA1;" FontFamily="{DynamicResource FontIcoFont}"
                               FontSize="48" Foreground="#33FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock Text="Genre browsing coming soon" FontSize="16"
                               Foreground="#66FFFFFF" Margin="0,12,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="Metadata support is planned for a future update."
                               FontSize="12" Foreground="#44FFFFFF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Panel 4: Stats Tab -->
            <Grid x:Name="StatsPanel" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20">
                    <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                        <DockPanel Margin="4,0,4,12">
                            <TextBlock Text="Music Library" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <Button Content="Refresh" Command="{Binding RefreshStatsCommand}"
                                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    Foreground="{DynamicResource GlyphBrush}" FontSize="11">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock x:Name="Tb" Text="{TemplateBinding Content}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontSize="{TemplateBinding FontSize}"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Tb" Property="TextDecorations" Value="Underline"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DockPanel>

                        <!-- Row 1 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="{Binding GamesWithMusic}" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Games with Music" FontSize="11" Foreground="#88FFFFFF" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalSongs}" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Total Songs" FontSize="11" Foreground="#88FFFFFF" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <!-- Row 2 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="{Binding StorageUsed}" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Storage Used" FontSize="11" Foreground="#88FFFFFF" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="{Binding GamesWithoutMusic}" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="Games without Music" FontSize="11" Foreground="#88FFFFFF" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!-- NOW PLAYING EXPANDED VIEW (overlay)                            -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Grid x:Name="NowPlayingOverlay"
          Visibility="{Binding IsNowPlayingExpanded, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
          Background="#F0101025">

        <Grid MaxWidth="600" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Close button -->
                <RowDefinition Height="Auto"/>  <!-- Cover art -->
                <RowDefinition Height="Auto"/>  <!-- Song info -->
                <RowDefinition Height="Auto"/>  <!-- Visualizer -->
                <RowDefinition Height="Auto"/>  <!-- Progress -->
                <RowDefinition Height="Auto"/>  <!-- Controls -->
            </Grid.RowDefinitions>

            <!-- Close / minimize button -->
            <Button Grid.Row="0" HorizontalAlignment="Right" Margin="0,0,0,12"
                    Command="{Binding ToggleNowPlayingCommand}" Cursor="Hand"
                    Style="{StaticResource TransportButton}" Width="32" Height="32">
                <TextBlock Text="&#xEEE4;" FontFamily="{DynamicResource FontIcoFont}"
                           FontSize="16" Foreground="#88FFFFFF"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>

            <!-- Large cover art -->
            <Border Grid.Row="1" Width="280" Height="280" CornerRadius="12"
                    Background="#1a1a2e" ClipToBounds="True"
                    HorizontalAlignment="Center" Margin="0,0,0,24">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.5" Color="Black"/>
                </Border.Effect>
                <Image Source="{Binding CoverArt}" Stretch="UniformToFill"
                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>

            <!-- Song info -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,16">
                <TextBlock Text="{Binding SongTitle}" FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrush}" TextAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="500"/>
                <TextBlock FontSize="14" Foreground="#99FFFFFF" TextAlignment="Center"
                           Margin="0,6,0,0">
                    <Run Text="{Binding SongArtist, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Text="{Binding NowPlayingGameName}" FontSize="12"
                           Foreground="#9B8EC4" TextAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Spectrum visualizer (large) -->
            <Border x:Name="ExpandedVisualizerContainer" Grid.Row="3"
                    Height="64" Margin="20,0,20,20"
                    Background="#08FFFFFF" CornerRadius="8" ClipToBounds="True"/>

            <!-- Progress bar -->
            <StackPanel Grid.Row="4" Margin="20,0,20,8">
                <Grid Height="5">
                    <Border Background="#20FFFFFF" CornerRadius="3"/>
                    <Border Background="{DynamicResource GlyphBrush}" CornerRadius="3"
                            HorizontalAlignment="Left">
                        <Border.Width>
                            <MultiBinding Converter="{x:Static local:ProgressWidthConverter.Instance}">
                                <Binding Path="ProgressPercent"/>
                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Grid}"/>
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Grid>
                <DockPanel Margin="0,6,0,0">
                    <TextBlock Text="{Binding ElapsedTime}" FontSize="11" Foreground="#88FFFFFF"/>
                    <TextBlock Text="{Binding RemainingTime}" FontSize="11" Foreground="#88FFFFFF"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                </DockPanel>
            </StackPanel>

            <!-- Transport controls (large, centered) -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,12,0,0">
                <!-- Previous -->
                <Button Width="44" Height="44" Command="{Binding PreviousCommand}"
                        Style="{StaticResource TransportButton}" ToolTip="Previous">
                    <TextBlock Text="&#xEC78;" FontFamily="{DynamicResource FontIcoFont}"
                               FontSize="20" Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>

                <!-- Play/Pause (large primary) -->
                <Button Command="{Binding PlayPauseCommand}" Margin="16,0"
                        Cursor="Hand" ToolTip="Play / Pause">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="#30FFFFFF"
                                    CornerRadius="24" Width="48" Height="48">
                                <TextBlock Text="{Binding PlayPauseIcon}"
                                           FontFamily="{DynamicResource FontIcoFont}"
                                           FontSize="22" Foreground="{DynamicResource TextBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#45FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Skip -->
                <Button Command="{Binding SkipCommand}" Width="44" Height="44"
                        IsEnabled="{Binding CanSkip}"
                        Style="{StaticResource TransportButton}" ToolTip="Skip to next song">
                    <TextBlock Text="&#xEC6E;" FontFamily="{DynamicResource FontIcoFont}"
                               FontSize="20" Foreground="{DynamicResource TextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>

    </Grid>
</UserControl>
