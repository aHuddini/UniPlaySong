<UserControl x:Class="UniPlaySong.Features.MusicInfoCard.Views.MusicInfoCardDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="580" d:DesignWidth="620"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Outer card. Window is transparent (raw WPF Window, not Playnite-
         managed), so the only Background pixels the user sees come from
         this Border. The layer order inside the inner Grid is:
            backdrop image (blurred) → dark veil → icon-tint → content.
         OuterCardBorder.Background acts as a fallback when the game has
         no BackgroundImage and the Image source stays null. -->
    <Border x:Name="OuterCardBorder"
            Background="#1C0F22"
            BorderBrush="#3D3D3D"
            BorderThickness="1"
            CornerRadius="10"
            Margin="0">
        <Grid ClipToBounds="True">
            <!-- BACKDROP LAYER: blurred game BackgroundImage. Source is
                 provided at Initialize() time; null means no image was
                 found, in which case the OuterCardBorder Background shows
                 through. Opacity 0.55 lets the dark veil dim it further. -->
            <Image x:Name="BlurredBackdrop"
                   Stretch="UniformToFill"
                   StretchDirection="Both"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Opacity="0.45">
                <Image.Effect>
                    <BlurEffect Radius="45" KernelType="Gaussian" RenderingBias="Performance"/>
                </Image.Effect>
            </Image>

            <!-- Dark veil on top of the blurred backdrop so foreground
                 text stays readable against busy backdrops. ~80% black
                 (was 60% / 0x99 previously) — darker veil bought us the
                 readability needed when the backdrop image is bright or
                 high-contrast. The 0.55 opacity on the image above ALSO
                 helps; combined, the visible backdrop sits at ~10% of
                 its original brightness. -->
            <Border Background="#CC000000" IsHitTestVisible="False"/>

            <!-- Subtle whole-card tint layer — sets the icon-derived
                 hue cast at ~3% alpha. Ties the dark veil to the icon's
                 dominant color. Set at runtime in code-behind. -->
            <Border x:Name="CardTintLayer"
                    Background="Transparent"
                    IsHitTestVisible="False"/>

            <!-- Thin accent strip at the very top, tinted by the icon's
                 primary color (set in code-behind). Visible signature
                 + acts as a soft visual anchor at the dialog's top edge. -->
            <Border x:Name="AccentStrip"
                    Height="3"
                    VerticalAlignment="Top"
                    CornerRadius="10,10,0,0"
                    Background="#7E57C2"/>

            <!-- Custom titlebar strip. Replaces Playnite's native chrome
                 (which we lost when switching to a transparent raw
                 Window). Drag anywhere on the strip to move the window;
                 the ✕ glyph closes. Title text matches the headline
                 subtitle. Z-orderd above the backdrop but below the
                 content rows. -->
            <Grid x:Name="TitleBar"
                  Height="32"
                  VerticalAlignment="Top"
                  Margin="0,3,0,0"
                  Background="#01000000"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="1"
                        x:Name="TitleBarCloseButton"
                        Width="40"
                        Height="32"
                        Cursor="Hand"
                        Click="CloseButton_Click"
                        ToolTip="Close (Esc)">
                    <!-- Inline style overrides Playnite's default Button
                         chrome (which gave us the muted #CCCCCC glyph on
                         a near-invisible transparent background). Custom
                         template puts a bright white glyph on a hover-
                         lit background so the close affordance reads
                         clearly at a glance, even against a busy backdrop. -->
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="HitBox"
                                    Background="Transparent"
                                    CornerRadius="0,10,0,0">
                                <TextBlock x:Name="Glyph"
                                           Text="✕"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HitBox" Property="Background" Value="#33FFFFFF"/>
                                    <Setter TargetName="Glyph" Property="Foreground" Value="#FF5555"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="HitBox" Property="Background" Value="#55FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Top margin accounts for the title bar strip above so
                 the icon + game name don't overlap the close button. -->
            <Grid Margin="20,38,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header (icon + title) -->
                    <RowDefinition Height="Auto"/>  <!-- Loading indicator -->
                    <RowDefinition Height="*"/>     <!-- Stats body -->
                    <RowDefinition Height="Auto"/>  <!-- Close button -->
                </Grid.RowDefinitions>

                <!-- Header: icon + title -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon container. The DropShadowEffect is on the Image
                         element itself (not this Border) so the shadow follows
                         the icon's actual transparency rather than the opaque
                         Border background. Without this, the entire 80x80
                         rectangle becomes the shadow source and the "glow"
                         renders as a near-black halo around the dark Border. -->
                    <Grid Grid.Column="0"
                          Width="80"
                          Height="80"
                          Margin="0,0,18,0">
                        <!-- Placeholder shows when no icon resolves. Kept on
                             a faint Border for visual presence so empty-icon
                             games still get a recognizable card identity. -->
                        <Border x:Name="IconPlaceholderBorder"
                                CornerRadius="10"
                                Background="#0A0A0A"
                                Visibility="Visible">
                            <TextBlock x:Name="IconPlaceholder"
                                       Text="♪"
                                       FontSize="50"
                                       Foreground="#666666"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Image x:Name="GameIconImage"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed">
                            <Image.Effect>
                                <DropShadowEffect x:Name="IconGlowEffect"
                                                  Color="#7E57C2"
                                                  BlurRadius="20"
                                                  ShadowDepth="0"
                                                  Opacity="0.75"
                                                  RenderingBias="Performance"/>
                            </Image.Effect>
                            <!-- BitmapCache renders icon+effect to a cached
                                 bitmap so WPF stops recomputing the shadow
                                 every frame when sibling visuals animate.
                                 Eliminates the flicker the user observed
                                 during the StatsPanel opacity fade-in. -->
                            <Image.CacheMode>
                                <BitmapCache EnableClearType="False"
                                             SnapsToDevicePixels="True"/>
                            </Image.CacheMode>
                        </Image>
                    </Grid>

                    <!-- Title block -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderSubtitle"
                                   Text="🎵 Music Info Card"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="#BB86FC"
                                   Margin="0,0,0,4"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="GameNameText"
                                   Text="..."
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>

                <!-- Loading indicator (visible until stats arrive) -->
                <StackPanel x:Name="LoadingPanel"
                            Grid.Row="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,8"
                            Visibility="Collapsed">
                    <ProgressBar IsIndeterminate="True" Width="220" Height="4"/>
                    <TextBlock Text="Reading metadata..."
                               FontSize="11"
                               Foreground="#888888"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Stats body -->
                <ScrollViewer x:Name="StatsScroll"
                              Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,4,0,12">
                    <StackPanel x:Name="StatsPanel" Opacity="0">
                        <!-- Headline: file/track counts -->
                        <Border Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock x:Name="FileCountText"
                                               Text="—"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#BB86FC"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Files"
                                               FontSize="11"
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Rectangle Grid.Column="0"
                                           Width="1"
                                           Fill="#3A3A3A"
                                           HorizontalAlignment="Right"
                                           Margin="0,6"/>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TotalDurationText"
                                               Text="—"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#03DAC5"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Total Duration"
                                               FontSize="11"
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <Rectangle Grid.Column="1"
                                           Width="1"
                                           Fill="#3A3A3A"
                                           HorizontalAlignment="Right"
                                           Margin="0,6"/>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TotalSizeText"
                                               Text="—"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="#FFB74D"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="On Disk"
                                               FontSize="11"
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Playlist info (only visible when playlists present) -->
                        <Border x:Name="PlaylistPanel"
                                Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="🎼 Playlists"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="PlaylistInfoText"
                                           Foreground="#CCCCCC"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Longest / shortest -->
                        <Border Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Longest:" Foreground="#888888" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" x:Name="LongestTitleText" Text="—" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" x:Name="LongestDurationText" Text="" Foreground="#03DAC5" Margin="8,0,0,0"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Shortest:" Foreground="#888888" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" x:Name="ShortestTitleText" Text="—" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" x:Name="ShortestDurationText" Text="" Foreground="#03DAC5" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Avg bitrate (hidden when not applicable) -->
                        <Border x:Name="BitratePanel"
                                Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Average Bitrate" Foreground="#888888"/>
                                <TextBlock Grid.Column="1" x:Name="BitrateText" Text="—" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <!-- Format breakdown -->
                        <Border Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Format Breakdown"
                                           FontWeight="SemiBold"
                                           Foreground="#FFFFFF"
                                           Margin="0,0,0,6"/>
                                <ItemsControl x:Name="FormatList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Extension}" Foreground="#BB86FC" FontFamily="Consolas"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Percentage}" Foreground="#CCCCCC"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Count}" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Unreadable count (only when >0) -->
                        <Border x:Name="UnreadablePanel"
                                Background="#3A2222"
                                CornerRadius="8"
                                Padding="14,8"
                                Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <TextBlock x:Name="UnreadableText"
                                       Foreground="#FFA8A8"
                                       FontSize="12"/>
                        </Border>

                        <!-- Song list -->
                        <Border x:Name="SongListPanel"
                                Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Songs"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFFF"/>
                                    <TextBlock Grid.Column="1"
                                               x:Name="SongListCountText"
                                               Foreground="#888888"
                                               FontSize="11"/>
                                </Grid>
                                <ItemsControl x:Name="SongList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#80222222"
                                                    CornerRadius="4"
                                                    Padding="10,6"
                                                    Margin="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Background="{Binding ChipBackground}"
                                                            CornerRadius="3"
                                                            Padding="5,2"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding ChipText}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="10"
                                                                   Foreground="#FFFFFF"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               Foreground="#FFFFFF"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding SizeText}"
                                                               Foreground="#888888"
                                                               FontSize="11"
                                                               Margin="8,0,0,0"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding DurationText}"
                                                               Foreground="#03DAC5"
                                                               FontSize="12"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Empty state -->
                        <TextBlock x:Name="EmptyStateText"
                                   Text="No music files found for this game."
                                   Foreground="#888888"
                                   FontStyle="Italic"
                                   HorizontalAlignment="Center"
                                   Margin="0,20"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Close button -->
                <Button Grid.Row="3"
                        x:Name="CloseButton"
                        Content="Close"
                        Width="100"
                        Height="32"
                        HorizontalAlignment="Right"
                        Click="CloseButton_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
