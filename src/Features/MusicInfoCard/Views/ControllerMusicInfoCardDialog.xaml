<UserControl x:Class="UniPlaySong.Features.MusicInfoCard.Views.ControllerMusicInfoCardDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="760"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Outer card. Same backdrop+veil+tint stack as Desktop dialog.
         Larger CornerRadius matches the Fullscreen visual scale.
         Window is transparent + chromeless (raw WPF Window), so the
         only background pixels seen come from this Border. -->
    <Border x:Name="OuterCardBorder"
            Background="#1C0F22"
            BorderBrush="#3D3D3D"
            BorderThickness="1"
            CornerRadius="14"
            Margin="0">
        <Grid ClipToBounds="True">
            <Image x:Name="BlurredBackdrop"
                   Stretch="UniformToFill"
                   StretchDirection="Both"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   IsHitTestVisible="False"
                   Opacity="0.45">
                <Image.Effect>
                    <BlurEffect Radius="50" KernelType="Gaussian" RenderingBias="Performance"/>
                </Image.Effect>
            </Image>

            <!-- Dark veil ~80% black (was 60% / 0x99). Same readability
                 upgrade as the Desktop dialog. -->
            <Border Background="#CC000000" IsHitTestVisible="False"/>

            <Border x:Name="CardTintLayer"
                    Background="Transparent"
                    IsHitTestVisible="False"/>

            <!-- Accent strip across the top -->
            <Border x:Name="AccentStrip"
                    Height="4"
                    VerticalAlignment="Top"
                    CornerRadius="14,14,0,0"
                    Background="#7E57C2"/>

            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header (icon + title) -->
                    <RowDefinition Height="Auto"/>  <!-- Loader -->
                    <RowDefinition Height="*"/>     <!-- Stats body -->
                    <RowDefinition Height="Auto"/>  <!-- Footer hint -->
                </Grid.RowDefinitions>

                <!-- Header: icon + title -->
                <Grid Grid.Row="0" Margin="0,8,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon container — DropShadowEffect on the Image element
                         directly so the glow follows icon transparency rather
                         than the opaque Border background. See Desktop dialog
                         XAML for the full reasoning. -->
                    <Grid Grid.Column="0"
                          Width="110"
                          Height="110"
                          Margin="0,0,22,0">
                        <Border x:Name="IconPlaceholderBorder"
                                CornerRadius="14"
                                Background="#0A0A0A"
                                Visibility="Visible">
                            <TextBlock x:Name="IconPlaceholder"
                                       Text="♪"
                                       FontSize="70"
                                       Foreground="#666666"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <Image x:Name="GameIconImage"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed">
                            <Image.Effect>
                                <DropShadowEffect x:Name="IconGlowEffect"
                                                  Color="#7E57C2"
                                                  BlurRadius="28"
                                                  ShadowDepth="0"
                                                  Opacity="0.75"
                                                  RenderingBias="Performance"/>
                            </Image.Effect>
                            <Image.CacheMode>
                                <BitmapCache EnableClearType="False"
                                             SnapsToDevicePixels="True"/>
                            </Image.CacheMode>
                        </Image>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderSubtitle"
                                   Text="🎵 Music Info Card"
                                   FontSize="18"
                                   FontWeight="Medium"
                                   Foreground="#BB86FC"
                                   Margin="0,0,0,6"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="GameNameText"
                                   Text="..."
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>

                <!-- Loader -->
                <StackPanel x:Name="LoadingPanel"
                            Grid.Row="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Center"
                            Margin="0,12,0,12"
                            Visibility="Collapsed">
                    <ProgressBar IsIndeterminate="True" Width="320" Height="6"/>
                    <TextBlock Text="Reading metadata..."
                               FontSize="16"
                               Foreground="#888888"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Stats body -->
                <ScrollViewer x:Name="StatsScroll"
                              Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="0,4,0,12">
                    <StackPanel x:Name="StatsPanel" Opacity="0">
                        <!-- Headline -->
                        <Border Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="10"
                                Padding="22,16"
                                Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock x:Name="FileCountText"
                                               Text="—"
                                               FontSize="42"
                                               FontWeight="Bold"
                                               Foreground="#BB86FC"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Files"
                                               FontSize="14"
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <Rectangle Grid.Column="0"
                                           Width="1"
                                           Fill="#3A3A3A"
                                           HorizontalAlignment="Right"
                                           Margin="0,8"/>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TotalDurationText"
                                               Text="—"
                                               FontSize="42"
                                               FontWeight="Bold"
                                               Foreground="#03DAC5"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Total Duration"
                                               FontSize="14"
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <Rectangle Grid.Column="1"
                                           Width="1"
                                           Fill="#3A3A3A"
                                           HorizontalAlignment="Right"
                                           Margin="0,8"/>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TotalSizeText"
                                               Text="—"
                                               FontSize="42"
                                               FontWeight="Bold"
                                               Foreground="#FFB74D"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="On Disk"
                                               FontSize="14"
                                               Foreground="#888888"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Playlist info -->
                        <Border x:Name="PlaylistPanel"
                                Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="10"
                                Padding="22,14"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="🎼 Playlists"
                                           FontWeight="SemiBold"
                                           FontSize="18"
                                           Foreground="#FFFFFF"
                                           Margin="0,0,0,6"/>
                                <TextBlock x:Name="PlaylistInfoText"
                                           Foreground="#CCCCCC"
                                           FontSize="16"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Longest / shortest -->
                        <Border Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="10"
                                Padding="22,14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Longest:" FontSize="16" Foreground="#888888"/>
                                    <TextBlock Grid.Column="1" x:Name="LongestTitleText" Text="—" FontSize="16" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" x:Name="LongestDurationText" Text="" FontSize="16" Foreground="#03DAC5" Margin="12,0,0,0"/>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Shortest:" FontSize="16" Foreground="#888888"/>
                                    <TextBlock Grid.Column="1" x:Name="ShortestTitleText" Text="—" FontSize="16" Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" x:Name="ShortestDurationText" Text="" FontSize="16" Foreground="#03DAC5" Margin="12,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Bitrate -->
                        <Border x:Name="BitratePanel"
                                Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="10"
                                Padding="22,14"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Average Bitrate" FontSize="16" Foreground="#888888"/>
                                <TextBlock Grid.Column="1" x:Name="BitrateText" Text="—" FontSize="16" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <!-- Format breakdown -->
                        <Border Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="10"
                                Padding="22,14"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Format Breakdown"
                                           FontWeight="SemiBold"
                                           FontSize="18"
                                           Foreground="#FFFFFF"
                                           Margin="0,0,0,8"/>
                                <ItemsControl x:Name="FormatList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Extension}" FontSize="16" Foreground="#BB86FC" FontFamily="Consolas"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Percentage}" FontSize="16" Foreground="#CCCCCC"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Count}" FontSize="16" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Unreadable -->
                        <Border x:Name="UnreadablePanel"
                                Background="#3A2222"
                                CornerRadius="10"
                                Padding="22,12"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <TextBlock x:Name="UnreadableText"
                                       Foreground="#FFA8A8"
                                       FontSize="14"/>
                        </Border>

                        <!-- Song list -->
                        <Border x:Name="SongListPanel"
                                Background="#A02A2A2A"
                                BorderBrush="#3A3A3A"
                                BorderThickness="0,1,0,0"
                                CornerRadius="10"
                                Padding="22,14"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Songs"
                                               FontWeight="SemiBold"
                                               FontSize="18"
                                               Foreground="#FFFFFF"/>
                                    <TextBlock Grid.Column="1"
                                               x:Name="SongListCountText"
                                               Foreground="#888888"
                                               FontSize="14"/>
                                </Grid>
                                <ItemsControl x:Name="SongList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#80222222"
                                                    CornerRadius="6"
                                                    Padding="14,10"
                                                    Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Border Grid.Column="0"
                                                            Background="{Binding ChipBackground}"
                                                            CornerRadius="4"
                                                            Padding="8,3"
                                                            Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding ChipText}"
                                                                   FontFamily="Consolas"
                                                                   FontSize="13"
                                                                   Foreground="#FFFFFF"/>
                                                    </Border>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               FontSize="15"
                                                               Foreground="#FFFFFF"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding SizeText}"
                                                               Foreground="#888888"
                                                               FontSize="14"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"/>

                                                    <TextBlock Grid.Column="3"
                                                               Text="{Binding DurationText}"
                                                               Foreground="#03DAC5"
                                                               FontSize="15"
                                                               Margin="14,0,0,0"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Empty state -->
                        <TextBlock x:Name="EmptyStateText"
                                   Text="No music files found for this game."
                                   Foreground="#888888"
                                   FontStyle="Italic"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   Margin="0,30"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer hint -->
                <TextBlock Grid.Row="3"
                           Text="🎮 Press B or Back to close"
                           FontSize="14"
                           Foreground="#888888"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
