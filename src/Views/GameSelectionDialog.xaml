<Window x:Class="UniPlaySong.Views.GameSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Games for Rotation"
        Width="500" Height="550"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Select games to use as default music rotation"
                   FontSize="14"
                   Foreground="White"
                   Margin="0,0,0,10"/>

        <!-- Search box -->
        <TextBox Grid.Row="1"
                 x:Name="SearchBox"
                 Height="28"
                 FontSize="13"
                 Background="#2d2d2d"
                 Foreground="White"
                 BorderBrush="#555"
                 Padding="5,3"
                 Margin="0,0,0,10"
                 TextChanged="SearchBox_TextChanged">
            <TextBox.Style>
                <Style TargetType="TextBox">
                    <Style.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter Property="Tag" Value="Search games..."/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TextBox.Style>
        </TextBox>

        <!-- Game list with checkboxes -->
        <ListBox Grid.Row="2"
                 x:Name="GameListBox"
                 Background="#252525"
                 BorderBrush="#444"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}"
                              Foreground="White"
                              Margin="2"
                              FontSize="13">
                        <CheckBox.Content>
                            <TextBlock Text="{Binding GameName}" TextWrapping="NoWrap"/>
                        </CheckBox.Content>
                    </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="2"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Selection count -->
        <TextBlock Grid.Row="3"
                   x:Name="SelectionCountText"
                   Text="0 game(s) selected"
                   FontSize="12"
                   Foreground="#888"
                   Margin="0,8,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Select All"
                    Width="80"
                    Height="28"
                    Margin="0,0,5,0"
                    Click="SelectAll_Click"/>
            <Button Content="Clear All"
                    Width="80"
                    Height="28"
                    Margin="0,0,15,0"
                    Click="ClearAll_Click"/>
            <Button Content="OK"
                    Width="80"
                    Height="28"
                    Margin="0,0,5,0"
                    IsDefault="True"
                    Click="OK_Click"/>
            <Button Content="Cancel"
                    Width="80"
                    Height="28"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
