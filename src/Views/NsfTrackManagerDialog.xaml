<UserControl x:Class="UniPlaySong.Views.NsfTrackManagerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:UniPlaySong.Views"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="720">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:NsfManagerTabToIndexConverter x:Key="EnumToIndexConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <TabControl Margin="8"
                SelectedIndex="{Binding ActiveTab, Converter={StaticResource EnumToIndexConverter}}"
                Style="{StaticResource MaterialDesignTabControl}">

        <TabItem Header="Split Tracks" IsEnabled="{Binding SplitTabEnabled}" ToolTip="{Binding SplitTabTooltip}">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.87"/>
                        </TextBlock.Foreground>
                        <Run Text="NSF Track Manager &#x2014; "/>
                        <Run Text="{Binding GameName, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Margin="0,3,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.60"/>
                        </TextBlock.Foreground>
                        <Run Text="{Binding FileName, Mode=OneWay}"/>
                        <Run Text=" &#x2014; "/>
                        <Run Text="{Binding Tracks.Count, Mode=OneWay}"/>
                        <Run Text=" tracks. Preview each, uncheck any you don&apos;t want, then Commit."/>
                    </TextBlock>
                </StackPanel>

                <!-- Selection toolbar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="SELECT ALL"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="11"
                            Padding="12,6"
                            MinHeight="32"
                            Margin="0,0,6,0"
                            Command="{Binding SelectAllCommand}"/>
                    <Button Content="SELECT NONE"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="11"
                            Padding="12,6"
                            MinHeight="32"
                            Margin="0,0,6,0"
                            Command="{Binding SelectNoneCommand}"/>
                    <Button Content="INVERT"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="11"
                            Padding="12,6"
                            MinHeight="32"
                            Command="{Binding InvertCommand}"/>
                </StackPanel>

                <!-- Track list -->
                <Border Grid.Row="2"
                        BorderThickness="1"
                        CornerRadius="3"
                        BorderBrush="{DynamicResource MaterialDesignDivider}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Tracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding IsKept, Mode=TwoWay}"/>

                                            <TextBlock Grid.Column="1"
                                                       Margin="10,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DisplayNumber}">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="White" Opacity="0.60"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>

                                            <TextBlock Grid.Column="2"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding Name}">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="White" Opacity="0.87"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>

                                            <TextBlock Grid.Column="3"
                                                       Margin="10,0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DurationDisplay}">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="White" Opacity="0.60"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>

                                            <!-- Preview toggle button -->
                                            <Button Grid.Column="4"
                                                    Width="32"
                                                    Height="32"
                                                    ToolTip="Preview"
                                                    Command="{Binding DataContext.TogglePreviewCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                        <Setter Property="Content">
                                                            <Setter.Value>
                                                                <materialDesign:PackIcon Kind="Play" Width="16" Height="16"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPreviewing}" Value="True">
                                                                <Setter Property="Content">
                                                                    <Setter.Value>
                                                                        <materialDesign:PackIcon Kind="Stop" Width="16" Height="16"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Footer -->
                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MaterialDesignBody2TextBlock}"
                                   Text="{Binding SelectionSummary}">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="White" Opacity="0.87"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <CheckBox Margin="0,4,0,0"
                                  IsChecked="{Binding PreserveOriginal, Mode=TwoWay}"
                                  Content="Preserve original NSF in backup folder"
                                  FontSize="12">
                            <CheckBox.Foreground>
                                <SolidColorBrush Color="White" Opacity="0.75"/>
                            </CheckBox.Foreground>
                        </CheckBox>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="COMMIT"
                                Margin="0,0,8,0"
                                MinWidth="90"
                                FontSize="11"
                                Padding="12,6"
                                MinHeight="32"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding CommitCommand}"/>
                        <Button Content="CANCEL"
                                MinWidth="90"
                                FontSize="11"
                                Padding="12,6"
                                MinHeight="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem Header="Edit Loops" IsEnabled="{Binding EditLoopsTabEnabled}" ToolTip="{Binding EditLoopsTabTooltip}">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header instructions -->
                <TextBlock Grid.Row="0"
                           Style="{StaticResource MaterialDesignBody2TextBlock}"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"
                           Text="Set a custom loop length for each mini-NSF. Leave blank to use the default 2:30. Values are in seconds (5&#x2013;600).">
                    <TextBlock.Foreground>
                        <SolidColorBrush Color="White" Opacity="0.75"/>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- Loop rows list -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding LoopRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,6"
                                            BorderBrush="{DynamicResource MaterialDesignDivider}"
                                            BorderThickness="0,0,0,1">
                                        <Grid VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DisplayNumber}">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="White" Opacity="0.60"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>

                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       Text="{Binding FileName}">
                                                <TextBlock.Foreground>
                                                    <SolidColorBrush Color="White" Opacity="0.87"/>
                                                </TextBlock.Foreground>
                                            </TextBlock>

                                            <TextBox Grid.Column="2"
                                                     Margin="8,0"
                                                     materialDesign:HintAssist.Hint="seconds"
                                                     Text="{Binding LoopSecondsInput, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{Binding ValidationMessage}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                <Setter Property="BorderBrush" Value="#E53935"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>

                                            <Button Grid.Column="3"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="32" Height="32"
                                                    Command="{Binding DataContext.ToggleLoopPreviewCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Content>
                                                    <materialDesign:PackIcon Width="16" Height="16">
                                                        <materialDesign:PackIcon.Style>
                                                            <Style TargetType="materialDesign:PackIcon">
                                                                <Setter Property="Kind" Value="Play"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPreviewing}" Value="True">
                                                                        <Setter Property="Kind" Value="Stop"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </materialDesign:PackIcon.Style>
                                                    </materialDesign:PackIcon>
                                                </Button.Content>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Footer -->
                <Grid Grid.Row="2" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Text="{Binding LoopsSummary}">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="White" Opacity="0.87"/>
                        </TextBlock.Foreground>
                    </TextBlock>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="SAVE"
                                Margin="0,0,8,0"
                                MinWidth="90"
                                FontSize="11"
                                Padding="12,6"
                                MinHeight="32"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding SaveLoopsCommand}"/>
                        <Button Content="CLOSE"
                                MinWidth="90"
                                FontSize="11"
                                Padding="12,6"
                                MinHeight="32"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>
