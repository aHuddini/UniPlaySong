<UserControl x:Class="UniPlaySong.Views.SimpleControllerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Controller-Optimized Styles -->
            <Style x:Key="ControllerListBoxItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                <Setter Property="MinHeight" Value="80"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="Padding" Value="16,12"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Top"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#2196F3"/>
                        <Setter Property="BorderBrush" Value="#1976D2"/>
                        <Setter Property="BorderThickness" Value="3"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                    <Trigger Property="IsFocused" Value="True">
                        <Setter Property="BorderBrush" Value="#FF9800"/>
                        <Setter Property="BorderThickness" Value="4"/>
                        <Setter Property="Background" Value="#FFF3E0"/>
                        <Setter Property="Foreground" Value="Black"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            
            <Style x:Key="ControllerButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Height" Value="50"/>
                <Setter Property="MinWidth" Value="140"/>
                <Setter Property="Margin" Value="8"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Controller Hint -->
            <RowDefinition Height="*"/>     <!-- Results -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" 
                   Name="DialogTitle"
                   Text="🎮 Download Music" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   Margin="0,0,0,16" 
                   HorizontalAlignment="Center"
                   Foreground="#2196F3"/>

        <!-- Controller Hint -->
        <Border Grid.Row="1" 
                Background="#E3F2FD" 
                BorderBrush="#2196F3" 
                BorderThickness="2" 
                CornerRadius="8" 
                Padding="16,8"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="#1976D2"
                           Text="🎮 Xbox Controller Support Active:"
                           TextAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock FontSize="12" 
                           Foreground="#1976D2"
                           TextAlignment="Center"
                           TextWrapping="Wrap">
                    <Run Text="🎮 A: Select/Download • B: Back/Cancel • X/Y: Preview • D-Pad Up/Down: Navigate list"/>
                    <LineBreak/>
                    <Run Text="🎮 LB/RB: Page through • LT/RT: Jump to top/bottom • D-Pad Left/Right: Cycle search term (on album screen)"/>
                    <LineBreak/>
                    <Run Text="⌨️ Keyboard: Arrow keys, Enter, Escape, F1 for preview"/>
                </TextBlock>
                <TextBlock Name="InputFeedback"
                           FontSize="12" 
                           Foreground="#FF9800"
                           TextAlignment="Center"
                           Margin="0,4,0,0"
                           Text="🎮 Loading download options..."
                           FontStyle="Italic"/>
            </StackPanel>
        </Border>

        <!-- Results List - Controller-Optimized -->
        <!-- Note: KeyboardNavigation.DirectionalNavigation="None" disables arrow key navigation -->
        <!-- This prevents double-navigation when D-pad is pressed (XInput + WPF both handling it) -->
        <ListBox Grid.Row="2"
                 Name="ResultsListBox"
                 ItemContainerStyle="{StaticResource ControllerListBoxItemStyle}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,16"
                 MinHeight="200"
                 KeyboardNavigation.DirectionalNavigation="None">
            <!-- Items will be populated dynamically -->
        </ListBox>

        <!-- Action Buttons Row — left = search variant buttons (album-selection step only);
             right = back / confirm. -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Bottom-left: search-variant buttons — re-run the search with a different suffix.
                 Visibility collapsed by default; shown only during album-selection step via code-behind. -->
            <StackPanel Name="SearchVariantPanel"
                        Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="Try: "
                           VerticalAlignment="Center"
                           Foreground="#BBBBBB"
                           FontSize="12"
                           Margin="4,0,8,0"/>
                <Button Name="VariantOstButton"
                        Content="OST"
                        Click="VariantButton_Click"
                        Tag="OST"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        MinWidth="70" Height="36" FontSize="12"
                        Margin="0,0,4,0"
                        ToolTip="Search for '{Game} OST'"/>
                <Button Name="VariantSoundtrackButton"
                        Content="Soundtrack"
                        Click="VariantButton_Click"
                        Tag="soundtrack"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        MinWidth="92" Height="36" FontSize="12"
                        Margin="0,0,4,0"
                        ToolTip="Search for '{Game} soundtrack'"/>
                <Button Name="VariantMusicButton"
                        Content="Music"
                        Click="VariantButton_Click"
                        Tag="music"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        MinWidth="70" Height="36" FontSize="12"
                        Margin="0,0,4,0"
                        ToolTip="Search for '{Game} music'"/>
                <Button Name="VariantThemeButton"
                        Content="Theme"
                        Click="VariantButton_Click"
                        Tag="theme"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        MinWidth="70" Height="36" FontSize="12"
                        ToolTip="Search for '{Game} theme'"/>
            </StackPanel>

            <!-- Bottom-right: existing back/confirm controller buttons (unchanged behavior). -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Name="CancelButton"
                        Content="Back / Cancel"
                        Style="{StaticResource ControllerButtonStyle}"
                        Click="CancelButton_Click"/>
                <Button Name="ConfirmButton"
                        Content="Select / Download"
                        Style="{StaticResource ControllerButtonStyle}"
                        Click="ConfirmButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>