<Window x:Class="UniPlaySong.Views.CompletionStatusSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Completion Statuses"
        Width="420" Height="420"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Only play game-specific music for games with these completion statuses:"
                   FontSize="13"
                   Foreground="White"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <!-- Status list with checkboxes -->
        <ListBox Grid.Row="1"
                 x:Name="StatusListBox"
                 Background="#252525"
                 BorderBrush="#444"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}"
                              Foreground="White"
                              Margin="2"
                              FontSize="13">
                        <CheckBox.Content>
                            <TextBlock Text="{Binding DisplayName}" TextWrapping="NoWrap"/>
                        </CheckBox.Content>
                    </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="2"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <!-- Selection count -->
        <TextBlock Grid.Row="2"
                   x:Name="SelectionCountText"
                   Text="0 status(es) selected"
                   FontSize="12"
                   Foreground="#888"
                   Margin="0,8,0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Select All"
                    Width="80"
                    Height="28"
                    Margin="0,0,5,0"
                    Click="SelectAll_Click"/>
            <Button Content="Clear All"
                    Width="80"
                    Height="28"
                    Margin="0,0,15,0"
                    Click="ClearAll_Click"/>
            <Button Content="OK"
                    Width="80"
                    Height="28"
                    Margin="0,0,5,0"
                    IsDefault="True"
                    Click="OK_Click"/>
            <Button Content="Cancel"
                    Width="80"
                    Height="28"
                    IsCancel="True"
                    Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
